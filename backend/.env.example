# OpenAI (obligatorio para LLM, embeddings, STT y TTS)
OPENAI_API_KEY=sk-tu-clave-aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Base de datos (SQLite por defecto, no requiere configuración extra)
DATABASE_URL=sqlite+aiosqlite:///./callcenter.db

# ChromaDB (persistencia local del vector store)
CHROMA_PERSIST_DIR=./chroma_data

# Twilio — opción 2: llamada telefónica (la opción 1 es simulación en el navegador)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Debe ser URL pública https cuando uses Twilio (ngrok http 8000)
PUBLIC_BASE_URL=http://localhost:8000

# Servidor
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
